{
  "name": "projectbuilder",
  "version": "1.1.0",
  "type": "module",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "rebuild:node": "npm rebuild better-sqlite3 sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3 -w sqlite3",
    "start": "npm run rebuild:node && node server.js",
    "start:electron": "npm run rebuild:electron && electron .",
    "electron": "npm run start:electron",
    "dist:win": "electron-builder --win nsis",
    "test": "node --test --test-isolation=none"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "de.benahrdt.projectbuilder",
    "productName": "ProjectBuilder",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "icon.png",
      "CHANGELOG.md",
      "server.js",
      "database/**/*",
      "routes/**/*",
      "utils/**/*",
      "public/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "BenAhrdt",
      "repo": "ProjectBuilder",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "sqlite3": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "^39.8.3",
    "electron-builder": "^26.15.3"
  }
}
